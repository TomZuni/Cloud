PORT=8080
# Ruta del archivo de base de datos H2 (compartido con el consumidor mediante
# el mismo volumen montado en /data en ambos contenedores).
H2_DB_PATH=/data/guias_despacho
DDL_AUTO=update
AWS_REGION=us-east-1
AWS_S3_BUCKET=your_bucket_name
AWS_S3_GUIDE_PREFIX=guias
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
AWS_SESSION_TOKEN=your_session_token_if_using_academy_or_voclabs
EFS_MOUNT_PATH=/mnt/efs

RABBITMQ_HOST=rabbitmq1
RABBITMQ_PORT=5672
RABBITMQ_USERNAME=guest
RABBITMQ_PASSWORD=guest

# API Gateway valida el JWT y Spring Security tambien protege el microservicio.
# Usa false solo para pruebas locales sin token.
JWT_VALIDATION_ENABLED=true

AZURE_AD_ISSUER_URI=https://login.microsoftonline.com/your-tenant-id/v2.0
AZURE_AD_ALLOWED_AUDIENCES=api://your-api-client-id,your-api-client-id
APP_SECURITY_DOWNLOAD_AUTHORITIES=SCOPE_guides.download,ROLE_GUIDES_DOWNLOAD
APP_SECURITY_MANAGE_AUTHORITIES=SCOPE_guides.manage,SCOPE_access_as_user,SCOPE_user_impersonation,ROLE_GUIDES_MANAGE

# Azure AD B2C con flujo de usuario. Usa el issuer/audience reales del token.
# AZURE_AD_ISSUER_URI=https://your-tenant.b2clogin.com/your-tenant-id/v2.0/
# AZURE_AD_JWK_SET_URI=https://your-tenant.b2clogin.com/your-tenant.onmicrosoft.com/B2C_1_your_flow/discovery/v2.0/keys
# AZURE_AD_ALLOWED_AUDIENCES=your-api-client-id
# AZURE_AD_ALLOWED_POLICIES=B2C_1_your_flow
